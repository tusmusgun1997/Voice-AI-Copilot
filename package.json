{
  "name": "voice-ai-observability-copilot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "HighLevel Voice AI observability copilot with a Node.js backend and Vue.js dashboard.",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "node server/index.js",
    "client": "vite --host 0.0.0.0",
    "build": "vite build",
    "db:schema": "node scripts/applySupabaseSchema.js",
    "preview": "vite preview --host 0.0.0.0",
    "start": "node server/index.js"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.9",
    "@lucide/vue": "^1.16.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "pg": "^8.21.0",
    "vue": "^3.5.34"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.4",
    "concurrently": "^9.2.1",
    "vite": "^6.4.2"
  },
  "engines": {
    "node": ">=18.17"
  }
}
